{
  "expo": {
    "name": "YouthConnect Health",
    "slug": "youthconnect-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dindav.youthconnect"
    },
    "android": {
      "package": "com.dindav.youthconnect",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "YouthConnect Health",
      "shortName": "YouthConnect",
      "themeColor": "#0066CC",
      "backgroundColor": "#F8FAFC",
      "display": "standalone",
      "orientation": "portrait"
    },
    "extra": {
      "eas": {
        "projectId": "eeffc0db-cc91-484c-876e-55f3ab498f3a"
      }
    },
    "plugins": [
      "expo-font",
      "expo-status-bar"
    ]
  }
